{
    "name": "psc-acme/compiler-cart",
    "description": "Package compiler-cart for psc-acme organization",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\CompilerCart\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "illuminate/support": "^11.0",
        "predis/predis": "^2.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "symfony/phpunit-bridge": "^7.0",
        "phpunit/phpunit": "^11.0"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}